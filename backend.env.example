# Backend Environment Configuration (.env)
# Copy this file to .env and fill in your actual values

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
APP_NAME=SocialHub AI
APP_VERSION=1.0.0
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=socialhub_ai_dev
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=true
DATABASE_MIGRATIONS_RUN=false

# Database connection string (alternative to individual vars)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socialhub_ai_dev

# ============================================================================
# REDIS
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# RABBITMQ
# ============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345678
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_12345678
JWT_REFRESH_EXPIRATION=7d

# ============================================================================
# META (INSTAGRAM & FACEBOOK) OAUTH
# ============================================================================
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_meta_verify_token
META_ACCESS_TOKEN_ENCRYPTION_KEY=your_32_char_encryption_key_for_tokens
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_PAGE_ID=your_facebook_page_id

# OAuth Redirect URLs
OAUTH_CALLBACK_URL=http://localhost:3001/auth/oauth/callback
META_OAUTH_REDIRECT_URL=http://localhost:3001/auth/meta/callback

# Webhook Configuration
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WEBHOOK_PATH=/webhooks/meta
WEBHOOK_URL=http://localhost:3001/webhooks/meta

# ============================================================================
# GOOGLE OAUTH
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ============================================================================
# AI PROVIDERS
# ============================================================================
# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_ORG_ID=your_org_id_if_applicable
OPENAI_MODEL=gpt-4-turbo
OPENAI_DEFAULT_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=300

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Default AI Model
DEFAULT_AI_MODEL=openai # 'openai' or 'gemini'

# ============================================================================
# AWS S3
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=socialhub-ai-bucket
AWS_S3_CDN_URL=https://d123456789.cloudfront.net
S3_UPLOAD_DIR=uploads/
S3_MAX_FILE_SIZE=10485760 # 10MB in bytes

# ============================================================================
# STRIPE PAYMENT PROCESSING
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret
STRIPE_CURRENCY=USD

# Stripe Product/Price IDs
STRIPE_PRODUCT_FREE=prod_free
STRIPE_PRODUCT_PRO=prod_pro
STRIPE_PRODUCT_AGENCY=prod_agency

STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly

# ============================================================================
# SENDGRID EMAIL
# ============================================================================
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@socialhubai.com
SENDGRID_FROM_NAME=SocialHub AI

# Email Templates
SENDGRID_WELCOME_TEMPLATE_ID=d-your_template_id
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=d-your_template_id
SENDGRID_VERIFICATION_TEMPLATE_ID=d-your_template_id

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug # debug, info, warn, error
LOG_FORMAT=json # json or text
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=14d

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================================================
# SECURITY
# ============================================================================
ENCRYPTION_KEY=your_32_char_encryption_key_for_sensitive_data
ENCRYPTION_IV_LENGTH=16

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# ============================================================================
# WEBHOOKS & QUEUE PROCESSING
# ============================================================================
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000
WEBHOOK_TIMEOUT=30000 # 30 seconds
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_AI_REPLIES=true
FEATURE_AUTOMATION_BUILDER=true
FEATURE_COMMENT_TO_DM=true
FEATURE_LEAD_GENERATION=true
FEATURE_TEAM_MANAGEMENT=true
FEATURE_ANALYTICS=true
FEATURE_CRM_INTEGRATION=true

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
SENTRY_DSN=your_sentry_dsn_for_error_tracking
DATADOG_API_KEY=your_datadog_api_key
POSTHOG_API_KEY=your_posthog_api_key

# ============================================================================
# SCHEDULED JOBS
# ============================================================================
SCHEDULE_TOKEN_REFRESH_INTERVAL=3600000 # 1 hour
SCHEDULE_ANALYTICS_SYNC_INTERVAL=3600000 # 1 hour
SCHEDULE_WEBHOOK_CLEANUP_INTERVAL=86400000 # 24 hours
SCHEDULE_SUBSCRIPTION_SYNC_INTERVAL=86400000 # 24 hours

# ============================================================================
# ADMIN PANEL
# ============================================================================
ADMIN_EMAIL=admin@socialhubai.com
ADMIN_PASSWORD_RESET_TOKEN_EXPIRY=3600 # 1 hour
ADMIN_SESSION_TIMEOUT=1800 # 30 minutes

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Slack Notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url
SLACK_BOT_TOKEN=your_slack_bot_token

# Discord Notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ============================================================================
# TESTING
# ============================================================================
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socialhub_ai_test
TEST_REDIS_URL=redis://localhost:6379/1
