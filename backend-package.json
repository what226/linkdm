{
  "name": "socialhub-ai-backend",
  "version": "1.0.0",
  "description": "SocialHub AI - Backend API (NestJS)",
  "author": "SocialHub AI Team",
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "start:worker": "node dist/workers/main.js",
    "db:migrate": "typeorm migration:generate -n",
    "db:migration:run": "typeorm migration:run",
    "db:migration:revert": "typeorm migration:revert",
    "db:seed": "node dist/database/seeders/seed.js",
    "db:reset": "typeorm query \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && npm run db:migration:run",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm",
    "docker:build": "docker build -t socialhub-ai-backend:latest .",
    "docker:run": "docker run -p 3001:3001 socialhub-ai-backend:latest"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.13",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.13",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/typeorm": "^9.0.1",
    "@nestjs/cache-manager": "^2.1.1",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/swagger": "^7.1.11",
    "@nestjs/event-emitter": "^2.0.1",
    "@nestjs/bull": "^10.0.1",
    "@liaoliaots/nestjs-redis": "^9.0.5",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.3",
    "bull": "^4.11.4",
    "cache-manager": "^5.2.4",
    "bcrypt": "^5.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17",
    "axios": "^1.6.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "joi": "^17.11.0",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "uuid": "^9.0.1",
    "nanoid": "^4.0.2",
    "lodash": "^4.17.21",
    "moment-timezone": "^0.5.45",
    "stripe": "^13.11.0",
    "openai": "^4.24.1",
    "@google/generative-ai": "^0.1.3",
    "aws-sdk": "^2.1557.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "nodemailer": "^6.9.7",
    "react-email": "^0.0.1",
    "slack-sdk": "^6.9.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "sentry-nestjs": "^0.0.1",
    "@sentry/node": "^7.81.0",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.2.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jest": "^29.5.11",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.5",
    "@types/compression": "^1.7.5",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/lodash": "^4.14.202",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
